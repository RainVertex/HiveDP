# demo.rainvertex.com icin ornek yapilandirma. Gercek dosya deploy/demo.env (gitignore'da).
NODE_ENV=production
API_PORT=4000
LOG_LEVEL=info

POSTGRES_USER=platform
POSTGRES_PASSWORD=
POSTGRES_DB=platform
# Sifre POSTGRES_PASSWORD ile ayni olmali, host adi compose servis adi olan postgres.
DATABASE_URL=postgresql://platform:CHANGE_ME@postgres:5432/platform?schema=public

WEB_ORIGIN=https://demo.rainvertex.com
AUTH_CALLBACK_URL=https://demo.rainvertex.com/auth/github/callback

# Callback https://demo.rainvertex.com/auth/github/callback olan bir GitHub OAuth app gerekir.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=
PLATFORM_REPO_URL=

# openssl rand -hex 32 ile uretin.
SESSION_SECRET=
SESSION_COOKIE_NAME=mep_sid
BOOTSTRAP_ADMIN_EMAIL=

SCAFFOLDER_SECRET_GITHUB_TOKEN=
INTEGRATION_SECRET_KEY=
APP_SECRET_MASTER_KEY=
ALLOW_PRIVATE_GRAFANA_BASEURL=false

CODING_RUNNER_IMAGE=coding-runner:latest
CODING_RUNNER_NETWORK=bridge
# Docker Desktop gVisor desteklemez, bos birakin (varsayilan runtime kullanilir).
CODING_RUNNER_RUNTIME=
CODING_RUNNER_CPUS=2
CODING_RUNNER_MEMORY=4g
CODING_RUNNER_PIDS_LIMIT=512
CODING_RUNNER_TIMEOUT_MS=1200000
CODING_WORKER_CONCURRENCY=2
CODING_WORKER_USER_CAP=2
CODING_WARM_POOL_SIZE=1
AGENT_WORKER_CONCURRENCY=10
AGENT_WORKER_USER_CAP=3

# Cloudflare Zero Trust panelinden tunel olusturunca verilen token.
TUNNEL_TOKEN=
