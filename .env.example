# Service ports, the single source of truth.
# POSTGRES_PORT is read by docker-compose.yml when bringing the DB up.
# API_PORT is read by apps/api (the backend) and apps/web's Vite proxy.
# WEB_PORT is read by apps/web (the Vite dev server).
# If you change POSTGRES_PORT, also update the host portion of DATABASE_URL.
# If you change WEB_PORT, also update WEB_ORIGIN and AUTH_CALLBACK_URL.
POSTGRES_PORT=5435
API_PORT=4000
WEB_PORT=3010

DATABASE_URL=postgresql://platform:platform@localhost:5435/platform?schema=public
NODE_ENV=development
# Log verbosity: trace | debug | info | warn | error | fatal.
LOG_LEVEL=info
WEB_ORIGIN=http://localhost:3010

# GitHub OAuth (create an OAuth app at https://github.com/settings/developers).
# Login eligibility is driven by the kind=github Integration rows configured at
# runtime via the Integrations admin page, not an env var. Any user who is an
# active member of at least one of those orgs can sign in.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# In dev, point this at the SPA origin so GitHub redirects the browser to Vite,
# which proxies /auth/* through to the API. Same-origin keeps the session cookie.
AUTH_CALLBACK_URL=http://localhost:3010/auth/github/callback

# Shared secret for the GitHub push webhook (mounted at
# /integrations/github/webhook). Must match the secret configured on each
# repo's webhook settings page. Leave blank to disable the endpoint, it
# returns 503 until this is set. Generate with e.g. `openssl rand -hex 32`.
GITHUB_WEBHOOK_SECRET=

# GitHub App: powers catalog sync, push webhooks, and PR automation. Read from
# env only (never the database). Create the App at https://github.com/settings/apps
# and install it on the org(s) you manage. GITHUB_APP_PRIVATE_KEY is a PEM with
# literal \n escapes on a single line.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# This platform's own GitHub repo URL. Its catalog entity is tagged "platform" on
# sync so the Platform Assistant can read it to answer "how does this app work"
# questions. Leave blank to disable the platform_source tools.
PLATFORM_REPO_URL=

SESSION_SECRET=replace-me-with-32-plus-random-bytes
SESSION_COOKIE_NAME=mep_sid

# On first login, this email (matched against the GitHub primary email) is auto-promoted to admin
BOOTSTRAP_ADMIN_EMAIL=

# Scaffolder secrets. Any env var prefixed with SCAFFOLDER_SECRET_ is exposed
# to actions via ctx.secrets.read("<NAME without prefix>"). publish:github and
# publish:github:pr push as the GitHub App bot and need no PAT. This token is
# only used by fetch:remote-template to clone PRIVATE skeleton repos (public
# skeletons, including the defaults, need none). Leave blank if your template
# skeleton repos are public.
SCAFFOLDER_SECRET_GITHUB_TOKEN=

# Master key used to encrypt sensitive Integration.config fields (e.g.
# webhook secrets). 32 bytes hex. Generate with
# `openssl rand -hex 32`. Rotating this invalidates every stored integration
# secret, re-enter tokens in the Integrations UI after rotation.
INTEGRATION_SECRET_KEY=

# ngrok auth token for the dev tunnel started by `yarn dev`. The tunnel
# exposes the backend (API_PORT) at a public https URL so external services
# (GitHub webhooks) can reach this machine. Get a free
# token at https://dashboard.ngrok.com/get-started/your-authtoken.
# Leave blank to disable the tunnel, `yarn dev` will skip it with a
# friendly message and still start the app + backend.
NGROK_AUTHTOKEN=

# -----------------------------------------------------------------------------
# LLM provider API keys are entered in the AI admin UI and stored encrypted in
# the database (AES-256-GCM via APP_SECRET_MASTER_KEY below), not via env vars.
# -----------------------------------------------------------------------------

# Controls whether private Grafana base URLs are allowed. false by default.
ALLOW_PRIVATE_GRAFANA_BASEURL=false

# Master key for encrypting admin-entered provider API keys (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET_MASTER_KEY=

# -----------------------------------------------------------------------------
# Coding agents (runtime "code"). A coding agent clones the connected repo in a
# sandbox, runs Aider over it, and opens a draft PR. It runs in the separate
# coding worker (apps/coding-worker), which spawns one Docker container per run
# from the image below. The agent's model key (e.g. OpenAI for GPT-5.5) comes
# from the encrypted provider credential in the AI admin UI, not from here.
# -----------------------------------------------------------------------------

# Required to run coding agents: the coding-runner image tag. Build it first with:
#   docker build -t coding-runner:latest apps/coding-runner
CODING_RUNNER_IMAGE=coding-runner:latest

# Docker network for each run's container. The container needs egress to the
# model provider API (e.g. OpenAI) and GitHub. For local dev use "bridge" (the
# default Docker network with internet access). In production create a network
# that allows egress ONLY to those hosts. Defaults to "none", which fails closed
# (no egress, so the clone cannot reach GitHub), so you must set this.
CODING_RUNNER_NETWORK=bridge

# Per-run container limits and timeout (optional; defaults shown).
CODING_RUNNER_CPUS=2
CODING_RUNNER_MEMORY=4g
CODING_RUNNER_TIMEOUT_MS=1200000

# The coding worker sets CODING_RUNTIME_ENABLED=1 for itself. Only set it here if
# you run the coding runtime inside the API process instead of the worker (not
# recommended: a long coding run would block other work).
# CODING_RUNTIME_ENABLED=1

# Coding worker concurrency (optional). CONCURRENCY is how many coding runs execute
# at once (each is one Docker container, so size it to host CPU/RAM: a container
# uses up to CODING_RUNNER_CPUS / CODING_RUNNER_MEMORY). USER_CAP bounds how many of
# those one user may hold at once so nobody monopolizes the pool.
CODING_WORKER_CONCURRENCY=3
CODING_WORKER_USER_CAP=2

# Warm container pool: keep this many sandbox containers pre-started (blocked on
# stdin) so a coding run skips container/runtime startup. Pair it with the coding
# concurrency above. TTL recycles idle warm containers so they pick up a freshly
# deployed image; HEALTH is the reaper interval that refills dead/expired ones.
CODING_WARM_POOL_SIZE=3
CODING_WARM_TTL_MS=1800000
CODING_WARM_HEALTH_MS=30000

# -----------------------------------------------------------------------------
# Chat agents (runtime "chat"). Drained by the separate agent worker
# (apps/agent-worker) with bounded concurrency, so one user's agents never wait
# behind another's and heavy LLM loops never block the API.
# -----------------------------------------------------------------------------

# How many chat runs execute at once (the p-limit pool size) and the per-user cap.
AGENT_WORKER_CONCURRENCY=10
AGENT_WORKER_USER_CAP=3
# Poll interval when the queue had nothing claimable (optional).
AGENT_WORKER_IDLE_MS=1000

# Hard wall-clock ceiling per chat run, so a hung LLM call cannot pin a slot
# forever. Cross-process Stop: a run polls this often for an API-issued cancel.
AGENT_RUN_TIMEOUT_MS=600000
AGENT_CANCEL_POLL_MS=3000
