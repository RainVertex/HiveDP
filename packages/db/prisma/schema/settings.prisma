// Generic key/value store for admin-managed platform settings. Values are
// JSON so a setting can hold a string, number, or object. For example the chat
// feature reads "chat.visionModelId" (the admin-selected vision model for image
// extraction) when that key is unset image input in chat is disabled.
model SystemSetting {
  key             String   @id
  value           Json
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedBy       User?    @relation("SystemSettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}
