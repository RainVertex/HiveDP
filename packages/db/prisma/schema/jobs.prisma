enum JobRunStatus {
  running
  succeeded
  failed
  cancelled
}

// How a job run was started. Mirrors the JobTrigger type in
// apps/api/src/jobs/types.ts.
enum JobTrigger {
  schedule
  manual
  startup
}

model JobRun {
  id                String       @id @default(cuid())
  jobName           String
  triggeredBy       JobTrigger
  triggeredByUserId String?
  startedAt         DateTime     @default(now())
  finishedAt        DateTime?
  status            JobRunStatus @default(running)
  durationMs        Int?
  error             String?
  requestId         String?
  triggeredByUser   User?        @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([jobName, startedAt])
  @@index([status])
  @@index([triggeredByUserId])
}

model JobState {
  name          String    @id
  enabled       Boolean   @default(true)
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  cursor        Json?
  updatedAt     DateTime  @updatedAt
}
