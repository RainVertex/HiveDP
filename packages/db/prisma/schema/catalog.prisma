enum CatalogEntityKind {
  service
  api
  library
  website
  database
  infrastructure
}

enum Lifecycle {
  experimental
  production
  deprecated
  development
}

enum ServiceStatus {
  healthy
  degraded
  down
}

enum CatalogEntitySource {
  manual
  scaffolder
  discovery
  agent
  seed
}

model CatalogEntity {
  id                  String                     @id @default(cuid())
  name                String
  description         String?
  kind                CatalogEntityKind
  lifecycle           Lifecycle                  @default(production)
  repoUrl             String?
  tags                String[]                   @default([])
  source              CatalogEntitySource        @default(manual)
  sourceRef           String?
  // Authoritative GitHub org pointer. Every entity belongs to exactly one
  // org, denormalized from the kind=github Integration.config.accountLogin.
  // Used for catalog visibility filtering against UserOrgMembership.
  accountLogin        String
  lastSeenAt          DateTime                   @default(now())
  staleSince          DateTime?
  yamlSpec            Json?
  autoApply           Boolean                    @default(false)
  // GitHub App auto-import bookkeeping. installationId links the entity to
  // the App installation that discovered it (used for cascade-stale on
  // uninstall). githubRepoId is GitHub's stable numeric repo id, preferred
  // over (name, kind) for upserts when present so renames don't fork the row.
  // needsOnboarding flips false the moment a valid catalog-info.yaml is seen,
  // unowned flips false when the agent (or a manual edit) attaches owners.
  needsOnboarding     Boolean                    @default(false)
  unowned             Boolean                    @default(false)
  installationId      Int?
  githubRepoId        Int?                       @unique
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  owners              CatalogEntityOwner[]
  healthSamples       ServiceHealthSample[]
  doraSnapshots       DoraMetricsSnapshot[]
  scorecardResults    ScorecardResult[]
  scorecardSnapshots  ScorecardEntitySnapshot[]
  docPages            DocPage[]
  docSync             DocSyncState?
  starredBy           StarredEntity[]
  workflowRuns        WorkflowRun[]
  deployments         Deployment[]
  pipelineSyncCursor  PipelineSyncCursor?
  observabilityConfig EntityObservabilityConfig?
  project             Project?
  teamGrants          CatalogEntityTeamGrant[]

  @@unique([name, kind])
  @@index([kind])
  @@index([staleSince])
  @@index([needsOnboarding])
  @@index([unowned])
  @@index([installationId])
  @@index([accountLogin])
}

model StarredEntity {
  userId    String
  entityId  String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity    CatalogEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([userId, entityId])
  @@index([entityId])
}

model CatalogEntityOwner {
  entityId  String
  teamId    String
  createdAt DateTime      @default(now())
  entity    CatalogEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  team      Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([entityId, teamId])
  @@index([teamId])
}

// GitHub team to repository access grants, synced from the org's team
// permissions during reconciliation. Unlike curated CatalogEntityOwner rows,
// these are derived from GitHub and drive project access at a level matching
// the granted repo permission (admin/maintain -> ADMIN, push -> WRITE,
// triage/pull -> READ).
model CatalogEntityTeamGrant {
  entityId   String
  teamId     String
  permission String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  entity     CatalogEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  team       Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([entityId, teamId])
  @@index([teamId])
}
